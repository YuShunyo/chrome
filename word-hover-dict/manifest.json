{
  "manifest_version": 3,
  "name": "悬停查词 Word Hover Dictionary",
  "version": "1.2",
  "description": "鼠标悬停在英文单词上自动弹出中英文释义，点击图标可开关（默认关闭）",
  "permissions": ["storage"],
  "host_permissions": [
    "https://dict.youdao.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/off/icon16.png",
      "32": "icons/off/icon32.png",
      "48": "icons/off/icon48.png",
      "128": "icons/off/icon128.png"
    },
    "default_title": "悬停查词（当前：关闭，点击开启）"
  },
  "icons": {
    "16": "icons/off/icon16.png",
    "32": "icons/off/icon32.png",
    "48": "icons/off/icon48.png",
    "128": "icons/off/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
